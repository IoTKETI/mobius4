{
  "_comment": "Copy this file to config/local.json and fill in your local values. local.json is gitignored and always takes priority over default.json.",
  "db": {
    "user": "your_db_user",
    "pw": "your_db_password"
  },
  "logging": {
    "level": "debug",
    "console": {
      "pretty": true
    },
    "file": {
      "enabled": false
    }
  },
  "security": {
    "helmet": {
      "enabled": false
    },
    "rateLimit": {
      "enabled": false
    }
  }
}
